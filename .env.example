# Copy to .env and fill in. .env is git-ignored.

# --- Postgres (local docker compose) ---
POSTGRES_URL=postgresql://drift:drift@localhost:5432/drift

# --- LLM provider (pick one; both can be set) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model selection (defaults shown).
DRIFT_LLM_PROVIDER=anthropic       # anthropic | openai
DRIFT_LLM_MODEL=claude-3-5-sonnet-20241022

# --- GitHub PR gateway ---
GITHUB_TOKEN=                       # PAT with `repo` scope
GITHUB_REPO=your-org/your-dbt-repo  # owner/name format
GITHUB_BASE_BRANCH=main

# --- Slack (optional) ---
SLACK_WEBHOOK_URL=

# --- Behavior flags ---
DRIFT_DRY_RUN=true                  # never open real PRs by default
DRIFT_LLM_DISABLED=false            # rule-only mode if true
DRIFT_POLL_INTERVAL_SECONDS=30
DRIFT_BLAST_RADIUS_MODEL_CAP=25
